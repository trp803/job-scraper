# Порт сервера (default: 3333)
PORT=3333

# Авторизація (обов'язково змінити!)
AUTH_USER=admin
AUTH_PASS=your_strong_password_here
SESSION_SECRET=your_random_secret_key_here

# Розклад парсера (cron-синтаксис, default: кожні 3 години)
SCRAPE_SCHEDULE=0 */3 * * *

# Telegram бот (опціонально — залиш порожнім щоб вимкнути)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# URL сайту (для посилань в Telegram повідомленнях)
APP_URL=http://localhost:3333
