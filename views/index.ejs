<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DevOps Jobs — Ukraine</title>
  <link rel="stylesheet" href="/style.css">
  <script>if(localStorage.getItem('theme')==='dark')document.documentElement.setAttribute('data-theme','dark')</script>
</head>
<body>

<!-- ─── SSE Notification Toast ─────────────────────────────────── -->
<div id="toast" class="toast toast-hidden">
  <span id="toast-msg"></span>
  <button onclick="reloadPage()" class="toast-btn">Оновити</button>
  <button onclick="closeToast()" class="toast-close">✕</button>
</div>

<!-- Шапка -->
<header>
  <div class="header-inner">
    <div class="logo">
      <span class="logo-icon">⚙</span>
      <span>DevOps Jobs</span>
      <span class="badge-new" id="new-badge"><%= stats.new %> нових</span>
    </div>
    <nav class="tab-nav">
      <a href="/" class="tab-link active">Вакансії</a>
      <a href="/analytics" class="tab-link">Аналітика</a>
      <a href="/tracker" class="tab-link">Відгуки</a>
      <a href="/logs" class="tab-link">Логи</a>
    </nav>
    <div class="stats">
      <span>Всього: <b id="stat-total"><%= stats.total %></b></span>
      <span>Сьогодні: <b><%= stats.today %></b></span>
    </div>
    <div class="scraper-status" id="scraper-status"></div>
    <a class="btn-export" href="/export/xlsx?source=<%= filter.source %>&search=<%= filter.search||'' %>&new=<%= filter.onlyNew?'1':'' %>&salary=<%= filter.hasSalary?'1':'' %>" title="Завантажити Excel">⬇ XLSX</a>
    <a class="btn-export" href="/export/csv?source=<%= filter.source %>&search=<%= filter.search||'' %>&new=<%= filter.onlyNew?'1':'' %>&salary=<%= filter.hasSalary?'1':'' %>" title="Завантажити CSV">⬇ CSV</a>
    <button class="btn-dark" id="btn-dark" onclick="toggleDark()" title="Темна тема">🌙</button>
    <button class="btn-scrape" id="btn-scrape" onclick="runScraper()">↻ Оновити</button>
  </div>
</header>

<!-- Фільтри -->
<div class="filters">
  <form method="GET" action="/" id="filterForm">

    <input type="text" name="search" placeholder="Пошук за назвою..."
      value="<%= filter.search || '' %>" class="input-search"
      onchange="this.form.submit()">

    <!-- Джерело -->
    <select name="source" onchange="this.form.submit()" class="select-source">
      <option value="all"       <%= filter.source==='all'       ?'selected':'' %>>Всі сайти</option>
      <option value="hh.ua"     <%= filter.source==='hh.ua'     ?'selected':'' %>>hh.ua</option>
      <option value="dou.ua"    <%= filter.source==='dou.ua'    ?'selected':'' %>>dou.ua</option>
      <option value="djinni.co" <%= filter.source==='djinni.co' ?'selected':'' %>>djinni.co</option>
      <option value="work.ua"   <%= filter.source==='work.ua'   ?'selected':'' %>>work.ua</option>
      <option value="rabota.ua" <%= filter.source==='rabota.ua' ?'selected':'' %>>rabota.ua</option>
    </select>

    <!-- Рівень -->
    <select name="level" onchange="this.form.submit()" class="select-source">
      <option value=""         <%= !filter.level             ?'selected':'' %>>Всі рівні</option>
      <option value="intern"   <%= filter.level==='intern'   ?'selected':'' %>>Intern</option>
      <option value="junior"   <%= filter.level==='junior'   ?'selected':'' %>>Junior</option>
      <option value="middle"   <%= filter.level==='middle'   ?'selected':'' %>>Middle</option>
      <option value="senior"   <%= filter.level==='senior'   ?'selected':'' %>>Senior</option>
      <option value="lead"     <%= filter.level==='lead'     ?'selected':'' %>>Lead</option>
    </select>

    <!-- Remote -->
    <select name="remote" onchange="this.form.submit()" class="select-source">
      <option value=""        <%= !filter.remote           ?'selected':'' %>>Будь-який формат</option>
      <option value="remote"  <%= filter.remote==='remote' ?'selected':'' %>>Remote</option>
      <option value="hybrid"  <%= filter.remote==='hybrid' ?'selected':'' %>>Hybrid</option>
      <option value="office"  <%= filter.remote==='office' ?'selected':'' %>>Office</option>
    </select>

    <!-- Тільки нові -->
    <label class="toggle">
      <input type="checkbox" name="new" value="1"
        <%= filter.onlyNew ? 'checked' : '' %> onchange="this.form.submit()">
      <span>Тільки нові</span>
    </label>

    <!-- Тільки з зарплатою -->
    <label class="toggle">
      <input type="checkbox" name="salary" value="1"
        <%= filter.hasSalary ? 'checked' : '' %> onchange="this.form.submit()">
      <span>З зарплатою</span>
    </label>

    <span class="results-count"><%= pagination.count %> вакансій</span>
  </form>

  <!-- Пілюлі джерел -->
  <div class="source-pills">
    <% stats.sources.forEach(s => { %>
      <a href="/?source=<%= s.source %>"
         class="pill <%= filter.source===s.source?'active':'' %>">
        <%= s.source %> <span class="pill-count"><%= s.cnt %></span>
      </a>
    <% }) %>
  </div>
</div>

<!-- Список вакансій -->
<main>
  <% if (vacancies.length === 0) { %>
    <div class="empty">
      <p>Вакансій не знайдено</p>
      <p class="text-muted">Спробуй змінити фільтри або натисни "↻ Оновити"</p>
    </div>
  <% } %>

  <% vacancies.forEach(v => { %>
  <article class="job-card <%= v.is_new ? 'is-new' : '' %> <%= v.is_viewed ? 'is-viewed' : '' %>"
           id="job-<%= v.id %>">

    <!-- Рядок 1: Джерело + рівень + remote + дата -->
    <div class="job-meta">
      <span class="source-tag source-<%= v.source.replace(/\./g,'-') %>"><%= v.source %></span>

      <% if (v.level) { %>
        <span class="level-tag level-<%= v.level.key %>"><%= v.level.label %></span>
      <% } %>

      <% if (v.workFormat) { %>
        <span class="format-tag format-<%= v.workFormat.key %>"><%= v.workFormat.label %></span>
      <% } %>

      <% if (v.is_new) { %><span class="tag-new">NEW</span><% } %>

      <span class="job-date">
        <% if (v.daysOld === 0) { %>сьогодні
        <% } else if (v.daysOld === 1) { %>вчора
        <% } else if (v.daysOld > 1) { %><%= v.daysOld %> дн. тому
        <% } else { %><%= v.published_at || '' %><% } %>
      </span>
    </div>

    <!-- Рядок 2: Заголовок -->
    <h2 class="job-title">
      <a href="<%= v.url %>" target="_blank" rel="noopener"
         onclick="markViewed(<%= v.id %>)"><%= v.title %></a>
      <a href="/vacancy/<%= v.id %>" class="ext-link" title="Деталі вакансії">⊙</a>
    </h2>

    <!-- Рядок 3: Компанія + ЗП + Локація -->
    <div class="job-info">
      <% if (v.company) { %>
        <span class="company"><%= v.company %></span>
      <% } %>
      <% if (v.salary) { %>
        <span class="salary"><%= v.salary %></span>
      <% } %>
      <% if (v.expYears) { %>
        <span class="exp-tag"><%= v.expYears %>+ р. досвіду</span>
      <% } %>
      <% if (v.location) { %>
        <span class="location">📍 <%= v.location %></span>
      <% } %>
    </div>

    <!-- Рядок 4: Tech теги -->
    <% if (v.techTags && v.techTags.length > 0) { %>
    <div class="tech-tags">
      <% v.techTags.forEach(t => { %><span class="tech-pill"><%= t %></span><% }) %>
    </div>
    <% } %>

    <!-- Рядок 5: Опис -->
    <% if (v.description) { %>
      <p class="job-desc"><%= v.description %></p>
    <% } %>

    <!-- Рядок 6: Дія відгук -->
    <div class="job-actions">
      <button class="btn-apply" onclick="applyJob(<%= v.id %>)" id="apply-btn-<%= v.id %>">
        ✉ Відгукнутись
      </button>
    </div>

  </article>
  <% }) %>
</main>

<!-- Пагінація -->
<% if (pagination.total > 1) { %>
<nav class="pagination">
  <% const pq = `source=${filter.source}&search=${filter.search||''}&new=${filter.onlyNew?'1':''}&level=${filter.level||''}&remote=${filter.remote||''}&salary=${filter.hasSalary?'1':''}` %>
  <% if (pagination.current > 1) { %>
    <a href="?page=<%= pagination.current-1 %>&<%= pq %>">← Назад</a>
  <% } %>
  <span>Стор. <%= pagination.current %> / <%= pagination.total %></span>
  <% if (pagination.current < pagination.total) { %>
    <a href="?page=<%= pagination.current+1 %>&<%= pq %>">Вперед →</a>
  <% } %>
</nav>
<% } %>

<footer>
  <a href="/analytics">Аналітика компаній</a>
  &nbsp;·&nbsp;
  <a href="/logs">Логи парсера</a>
  &nbsp;·&nbsp;
  <span id="sse-status" class="sse-indicator">●</span> live
</footer>

<!-- ─── JavaScript ──────────────────────────────────────────────── -->
<script>
// ── Переглянуто ────────────────────────────────────────────────
function markViewed(id) {
  fetch(`/viewed/${id}`, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
  const card = document.getElementById(`job-${id}`);
  if (card) {
    card.classList.remove('is-new');
    card.classList.add('is-viewed');
    card.querySelector('.tag-new')?.remove();
  }
}

// ── Ручний запуск парсера ──────────────────────────────────────
function runScraper() {
  const btn = document.getElementById('btn-scrape');
  btn.disabled = true;
  btn.textContent = '⏳ Запускаю...';

  fetch('/scrape', { method: 'POST' })
    .then(r => r.json())
    .then(d => {
      if (!d.ok) {
        btn.textContent = '↻ Оновити';
        btn.disabled = false;
        showToast(d.message || 'Помилка', false);
      }
      // Кнопка залишається заблокованою — SSE відреагує на done
    })
    .catch(() => { btn.textContent = '↻ Оновити'; btn.disabled = false; });
}

// ── Toast сповіщення ───────────────────────────────────────────
const toast    = document.getElementById('toast');
const toastMsg = document.getElementById('toast-msg');
let toastTimer;

function showToast(msg, isGood = true) {
  toastMsg.textContent = msg;
  toast.className = 'toast ' + (isGood ? 'toast-good' : 'toast-info');
  clearTimeout(toastTimer);
  // Автоматично ховаємо через 12 секунд
  toastTimer = setTimeout(closeToast, 12000);
}
function closeToast() {
  toast.classList.add('toast-hidden');
}
function reloadPage() {
  window.location.reload();
}

// ── SSE — підписка на події сервера ───────────────────────────
const sseIndicator = document.getElementById('sse-status');
let   sseRetries   = 0;

function connectSSE() {
  const es = new EventSource('/events');

  es.addEventListener('init', e => {
    const d = JSON.parse(e.data);
    updateBadge(d.newCount);
    if (d.running) setScraperRunning(true);
    sseIndicator.style.color = '#16a34a'; // зелений = з'єднано
    sseRetries = 0;
  });

  es.addEventListener('scraper-start', () => {
    setScraperRunning(true);
  });

  es.addEventListener('scraper-done', e => {
    const d = JSON.parse(e.data);
    setScraperRunning(false);

    // Оновлюємо лічильник
    const totalEl = document.getElementById('stat-total');
    if (totalEl) totalEl.textContent = d.total;
    updateBadge(d.newCount);

    // Показуємо toast
    if (d.newCount > 0) {
      showToast(`Знайдено ${d.newCount} нових вакансій!`);
    } else {
      showToast('Оновлення завершено — нових вакансій немає', false);
    }
  });

  es.onerror = () => {
    sseIndicator.style.color = '#dc2626'; // червоний = відключено
    es.close();
    // Автоматичне перепідключення з backoff
    sseRetries++;
    const delay = Math.min(1000 * Math.pow(2, sseRetries), 30000);
    setTimeout(connectSSE, delay);
  };
}

function setScraperRunning(running) {
  const btn    = document.getElementById('btn-scrape');
  const status = document.getElementById('scraper-status');
  if (running) {
    btn.disabled    = true;
    btn.textContent = '⏳ Парсер запущено...';
    if (status) { status.textContent = '⏳'; status.title = 'Парсер збирає вакансії'; }
  } else {
    btn.disabled    = false;
    btn.textContent = '↻ Оновити';
    if (status) { status.textContent = ''; }
  }
}

function updateBadge(count) {
  const badge = document.getElementById('new-badge');
  if (badge) {
    badge.textContent = count + ' нових';
    badge.style.display = count > 0 ? '' : 'none';
  }
}

// Підключаємо SSE при завантаженні сторінки
connectSSE();

// ── Dark mode ──────────────────────────────────────────
function toggleDark() {
  const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  const next = isDark ? 'light' : 'dark';
  document.documentElement.setAttribute('data-theme', next);
  localStorage.setItem('theme', next);
  document.getElementById('btn-dark').textContent = next === 'dark' ? '☀' : '🌙';
}
(function initTheme() {
  const saved = localStorage.getItem('theme') || 'light';
  if (saved === 'dark') {
    document.documentElement.setAttribute('data-theme', 'dark');
    const btn = document.getElementById('btn-dark');
    if (btn) btn.textContent = '☀';
  }
})();

// ── Відгук на вакансію ─────────────────────────────────────────
function applyJob(id) {
  const btn = document.getElementById(`apply-btn-${id}`);
  btn.disabled = true;
  fetch('/tracker/apply', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ vacancy_id: id, status: 'applied' }),
  })
    .then(r => r.json())
    .then(d => {
      if (d.ok) {
        btn.textContent = '✓ Відгукнулись';
        btn.classList.add('btn-applied');
      } else {
        btn.disabled = false;
      }
    })
    .catch(() => { btn.disabled = false; });
}

// Перевіряємо відгукнуті вакансії на поточній сторінці
(function checkApplied() {
  const ids = Array.from(document.querySelectorAll('[id^="apply-btn-"]'))
    .map(el => el.id.replace('apply-btn-', ''));
  ids.forEach(id => {
    fetch(`/api/tracker/check/${id}`)
      .then(r => r.json())
      .then(d => {
        if (d.application) {
          const btn = document.getElementById(`apply-btn-${id}`);
          if (btn) {
            btn.textContent = '✓ ' + statusLabel(d.application.status);
            btn.classList.add('btn-applied');
          }
        }
      });
  });
})();

function statusLabel(s) {
  const map = { applied: 'Відгукнулись', screening: 'Скринінг', interview: "Інтерв'ю", offer: 'Оффер', rejected: 'Відмовили', withdrawn: 'Відкликали' };
  return map[s] || s;
}
</script>

</body>
</html>
