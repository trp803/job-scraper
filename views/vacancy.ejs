<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= vacancy.title %> — DevOps Jobs</title>
  <link rel="stylesheet" href="/style.css">
  <script>if(localStorage.getItem('theme')==='dark')document.documentElement.setAttribute('data-theme','dark')</script>
</head>
<body>

<header>
  <div class="header-inner">
    <div class="logo">
      <span class="logo-icon">⚙</span>
      <span>DevOps Jobs</span>
    </div>
    <nav class="tab-nav">
      <a href="/" class="tab-link">Вакансії</a>
      <a href="/analytics" class="tab-link">Аналітика</a>
      <a href="/tracker" class="tab-link">Відгуки</a>
      <a href="/resume" class="tab-link">Резюме</a>
      <a href="/logs" class="tab-link">Логи</a>
    </nav>
    <button class="btn-dark" id="btn-dark" onclick="toggleDark()" title="Темна тема">🌙</button>
    <form method="POST" action="/logout" style="margin:0">
      <button type="submit" class="btn-logout" title="Вийти">↪ Вийти</button>
    </form>
  </div>
</header>

<main class="vd-wrap">

  <!-- Навігація -->
  <div class="vd-nav">
    <a href="/" class="vd-back">← До списку</a>
    <a href="<%= vacancy.url %>" target="_blank" rel="noopener" class="btn-open-site">
      Відкрити на <%= vacancy.source %> ↗
    </a>
  </div>

  <!-- Картка вакансії -->
  <article class="vd-card">

    <!-- Мета: джерело, рівень, remote, NEW -->
    <div class="job-meta">
      <span class="source-tag source-<%= vacancy.source.replace(/\./g,'-') %>"><%= vacancy.source %></span>

      <% if (vacancy.level) { %>
        <span class="level-tag level-<%= vacancy.level.key %>"><%= vacancy.level.label %></span>
      <% } %>

      <% if (vacancy.workFormat) { %>
        <span class="format-tag format-<%= vacancy.workFormat.key %>"><%= vacancy.workFormat.label %></span>
      <% } %>

      <% if (vacancy.is_new) { %><span class="tag-new">NEW</span><% } %>
    </div>

    <!-- Заголовок -->
    <h1 class="vd-title"><%= vacancy.title %></h1>

    <!-- Компанія, ЗП, Локація, досвід -->
    <div class="job-info vd-info">
      <% if (vacancy.company) { %>
        <span class="company vd-company"><%= vacancy.company %></span>
      <% } %>
      <% if (vacancy.salary) { %>
        <span class="salary"><%= vacancy.salary %></span>
      <% } %>
      <% if (vacancy.expYears) { %>
        <span class="exp-tag"><%= vacancy.expYears %>+ р. досвіду</span>
      <% } %>
      <% if (vacancy.location) { %>
        <span class="location">📍 <%= vacancy.location %></span>
      <% } %>
    </div>

    <!-- Tech теги -->
    <% if (vacancy.techTags && vacancy.techTags.length > 0) { %>
    <div class="tech-tags vd-tech">
      <% vacancy.techTags.forEach(t => { %><span class="tech-pill"><%= t %></span><% }) %>
    </div>
    <% } %>

    <!-- Опис -->
    <% if (vacancy.description) { %>
    <div class="vd-desc">
      <h3 class="vd-desc-title">Опис</h3>
      <p><%= vacancy.description %></p>
    </div>
    <% } else { %>
    <div class="vd-desc vd-desc-empty">
      <p>Детальний опис доступний на сайті роботодавця.</p>
    </div>
    <% } %>

    <!-- Відповідність резюме -->
    <% if (scoreData && scoreData.total > 0) {
      const sc = scoreData.score;
      const cls = sc >= 70 ? 'hi' : sc >= 40 ? 'mid' : 'lo';
    %>
    <div class="vd-score score-<%= cls %>">
      <span class="vd-score-pct"><%= sc %>%</span>
      <div>
        <b>Відповідність базового резюме</b><br>
        <span class="vd-score-detail">
          Збіг: <%= scoreData.matched %> з <%= scoreData.total %> ключових слів.
          <% if (scoreData.missing.length > 0) { %>
            Не вистачає: <%= scoreData.missing.slice(0,5).join(', ') %><%= scoreData.missing.length > 5 ? ` та ще ${scoreData.missing.length - 5}` : '' %>.
          <% } %>
        </span>
      </div>
    </div>
    <% } %>

    <!-- Дати -->
    <div class="vd-dates">
      <% if (vacancy.published_at) { %>
        <span>Опубліковано: <b><%= vacancy.published_at %></b></span>
      <% } %>
      <span>Знайдено: <b><%= vacancy.created_at?.slice(0, 10) %></b></span>
    </div>

    <!-- Нотатки -->
    <div class="vd-notes">
      <div class="vd-notes-label">Нотатки</div>
      <textarea class="vd-notes-textarea" id="vacancy-note"
        placeholder="Запиши тут що дізнався: зарплата на інтерв'ю, контакт рекрутера, враження..."
      ><%= note || '' %></textarea>
      <div class="vd-notes-status" id="note-status"></div>
    </div>

    <!-- Підготовка до інтерв'ю -->
    <% if (vacancy.techTags && vacancy.techTags.length > 0) { %>
    <div class="vd-prep">
      <button class="vd-prep-toggle" onclick="togglePrep(this)">
        <span>Підготовка до інтерв'ю</span>
        <span id="prep-chevron">▼</span>
      </button>
      <div class="vd-prep-body" id="prep-body"></div>
    </div>
    <% } %>

    <!-- Сопровідній лист -->
    <div class="vd-cover">
      <button class="vd-prep-toggle" onclick="toggleCover(this)">
        <span>Сопровідній лист</span>
        <span id="cover-chevron">▼</span>
      </button>
      <div class="vd-cover-body" id="cover-body">

        <!-- Вибір шаблону -->
        <div class="cover-templates">
          <button class="cover-tpl-btn active" data-tpl="classic" onclick="selectTpl(this,'classic')">
            <span class="cover-tpl-name">Класичний</span>
            <span class="cover-tpl-desc">Формальний, структурований</span>
          </button>
          <button class="cover-tpl-btn" data-tpl="motivational" onclick="selectTpl(this,'motivational')">
            <span class="cover-tpl-name">Мотиваційний</span>
            <span class="cover-tpl-desc">Живий, показує інтерес до компанії</span>
          </button>
          <button class="cover-tpl-btn" data-tpl="technical" onclick="selectTpl(this,'technical')">
            <span class="cover-tpl-name">Технічний</span>
            <span class="cover-tpl-desc">Вимоги ↔ досвід, по пунктах</span>
          </button>
        </div>

        <!-- Підстановочні змінні -->
        <div class="cover-vars">
          <label class="cover-var-label">Ваше ім'я
            <input class="cover-var-input" id="cv-name" value="<%= coverName || '' %>"
              placeholder="Іван Іваненко" oninput="regenerate()">
          </label>
          <label class="cover-var-label">Досвід (роки)
            <input class="cover-var-input" id="cv-exp" value="" placeholder="2"
              style="width:70px" oninput="regenerate()">
          </label>
          <label class="cover-var-label">Посилання (GitHub / LinkedIn)
            <input class="cover-var-input" id="cv-links" value=""
              placeholder="github.com/you" oninput="regenerate()">
          </label>
        </div>

        <!-- Редактор листа -->
        <textarea class="cover-textarea" id="cover-output" spellcheck="true"></textarea>

        <!-- Дії -->
        <div class="cover-actions">
          <button class="cover-btn-copy" onclick="copyCover()">Копіювати</button>
          <button class="cover-btn-regen" onclick="regenerate()">Оновити</button>
          <span class="cover-copy-status" id="cover-status"></span>
          <span style="margin-left:auto;font-size:.78rem;color:var(--text-muted)">
            Відредагуй під себе перед відправкою
          </span>
        </div>

      </div>
    </div>

  </article>

  <!-- Дії -->
  <%
    const STATUS_LABELS = {
      applied: 'Відгукнулись', screening: 'Скринінг',
      interview: "Інтерв'ю", offer: 'Оффер',
      rejected: 'Відмовили', withdrawn: 'Відкликали',
    };
  %>
  <div class="vd-actions">
    <button class="btn-apply" id="apply-btn" onclick="applyJob(<%= vacancy.id %>)">
      <% if (application) { %>
        ✓ <%= STATUS_LABELS[application.status] || application.status %>
      <% } else { %>
        ✉ Відгукнутись
      <% } %>
    </button>
    <a href="/resume/new?vacancy_id=<%= vacancy.id %>" class="btn-open-site" style="background:#7c3aed;color:#fff;border-color:#7c3aed">
      ✎ Написати резюме
    </a>
    <a href="<%= vacancy.url %>" target="_blank" rel="noopener" class="btn-open-site">
      Відкрити вакансію ↗
    </a>
  </div>

</main>

<script>
function applyJob(id) {
  const btn = document.getElementById('apply-btn');
  btn.disabled = true;
  fetch('/tracker/apply', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ vacancy_id: id, status: 'applied' }),
  })
    .then(r => r.json())
    .then(d => {
      if (d.ok) {
        btn.textContent = '✓ Відгукнулись';
        btn.classList.add('btn-applied');
      } else {
        btn.disabled = false;
      }
    })
    .catch(() => { btn.disabled = false; });
}

function statusLabel(s) {
  const map = { applied: 'Відгукнулись', screening: 'Скринінг', interview: "Інтерв'ю", offer: 'Оффер', rejected: 'Відмовили', withdrawn: 'Відкликали' };
  return map[s] || s;
}

// Ініціалізуємо статус кнопки якщо є відгук
<% if (application) { %>
(function() {
  const btn = document.getElementById('apply-btn');
  btn.textContent = '✓ ' + statusLabel('<%= application.status %>');
  btn.classList.add('btn-applied');
})();
<% } %>

// ─── Нотатки ─────────────────────────────────────────────────────
(function initNotes() {
  const ta     = document.getElementById('vacancy-note');
  const status = document.getElementById('note-status');
  if (!ta) return;
  let timer;
  ta.addEventListener('input', () => {
    clearTimeout(timer);
    status.textContent = '';
    timer = setTimeout(() => saveNote(ta.value), 800);
  });
  ta.addEventListener('keydown', e => {
    if ((e.ctrlKey || e.metaKey) && e.key === 's') {
      e.preventDefault();
      clearTimeout(timer);
      saveNote(ta.value);
    }
  });
})();

function saveNote(text) {
  const status = document.getElementById('note-status');
  fetch('/vacancy/<%= vacancy.id %>/note', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ note: text }),
  }).then(r => r.json()).then(d => {
    if (d.ok) { status.textContent = 'Збережено'; setTimeout(() => { status.textContent = ''; }, 2000); }
  }).catch(() => { status.textContent = 'Помилка збереження'; });
}

