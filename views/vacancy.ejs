const VACANCY_ID = <%= vacancy.id %>;
const TECH_TAGS  = <%- JSON.stringify(vacancy.techTags || []) %>;

function togglePrep(btn) {
  const body    = document.getElementById('prep-body');
  const chevron = document.getElementById('prep-chevron');
  const isOpen  = body.classList.toggle('open');
  chevron.textContent = isOpen ? '▲' : '▼';
  if (isOpen && !body.dataset.rendered) {
    renderPrep();
    body.dataset.rendered = '1';
  }
}

function renderPrep() {
  const body     = document.getElementById('prep-body');
  const lsKey    = 'prep_' + VACANCY_ID;
  const saved    = JSON.parse(localStorage.getItem(lsKey) || '{}');
  const matched  = TECH_TAGS.filter(tag => PREP_DB[tag]);

  if (matched.length === 0) {
    body.innerHTML = '<p style="color:var(--text-muted);font-size:.85rem">Специфічних тем не знайдено для цих тегів. Загальні DevOps знання:</p>';
    matched.push('Linux', 'Git');
  }

  let totalItems = 0, checkedItems = 0;
  let html = '';

  for (const tag of matched) {
    const items = PREP_DB[tag];
    if (!items) continue;
    html += `<div class="vd-prep-section"><div class="vd-prep-section-title">${tag}</div>`;
    items.forEach((item, i) => {
      const key     = `${tag}_${i}`;
      const checked = saved[key] || false;
      totalItems++;
      if (checked) checkedItems++;
      html += `<label class="vd-prep-item${checked ? ' checked' : ''}" data-key="${key}">
        <input type="checkbox" ${checked ? 'checked' : ''} onchange="togglePrepItem(this,'${key}')">
        ${item}
      </label>`;
    });
    html += '</div>';
  }

  const pct = totalItems > 0 ? Math.round(checkedItems / totalItems * 100) : 0;
  body.innerHTML = `<div class="vd-prep-progress">Готовність: ${checkedItems}/${totalItems} (${pct}%)</div>` + html;
}

function togglePrepItem(cb, key) {
  const lsKey = 'prep_' + VACANCY_ID;
  const saved = JSON.parse(localStorage.getItem(lsKey) || '{}');
  saved[key]  = cb.checked;
  localStorage.setItem(lsKey, JSON.stringify(saved));
  cb.closest('.vd-prep-item').classList.toggle('checked', cb.checked);
  // Оновити лічильник
  const body = document.getElementById('prep-body');
  const total   = body.querySelectorAll('.vd-prep-item').length;
  const checked = body.querySelectorAll('.vd-prep-item.checked').length;
  const pct     = total > 0 ? Math.round(checked / total * 100) : 0;
  const prog    = body.querySelector('.vd-prep-progress');
  if (prog) prog.textContent = `Готовність: ${checked}/${total} (${pct}%)`;
}

// ─── Сопровідній лист ────────────────────────────────────────────
const COVER_VACANCY = {
  title:    <%- JSON.stringify(vacancy.title || '') %>,
  company:  <%- JSON.stringify(vacancy.company || '') %>,
  tags:     <%- JSON.stringify(vacancy.techTags || []) %>,
  level:    <%- JSON.stringify(vacancy.level?.label || '') %>,
  desc:     <%- JSON.stringify((vacancy.description || '').slice(0, 800)) %>,
  salary:   <%- JSON.stringify(vacancy.salary || '') %>,
};

let currentTpl = 'classic';

function toggleCover(btn) {
  const body    = document.getElementById('cover-body');
  const chevron = document.getElementById('cover-chevron');
  const isOpen  = body.classList.toggle('open');
  chevron.textContent = isOpen ? '▲' : '▼';
  if (isOpen && !body.dataset.rendered) {
    body.dataset.rendered = '1';
    regenerate();
  }
}

function selectTpl(btn, tpl) {
  document.querySelectorAll('.cover-tpl-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  currentTpl = tpl;
  regenerate();
}

function getCoverVars() {
  return {
    name:    document.getElementById('cv-name').value.trim() || '[Ваше ім\'я]',
    exp:     document.getElementById('cv-exp').value.trim()  || 'N',
    links:   document.getElementById('cv-links').value.trim(),
    vacancy: COVER_VACANCY,
  };
}

// ── Шаблони ──────────────────────────────────────────────────────
const TEMPLATES = {

  classic(v) {
    const tags  = v.vacancy.tags.slice(0, 5).join(', ') || 'DevOps-інструментах';
    const co    = v.vacancy.company ? ` в компанії ${v.vacancy.company}` : '';
    const links = v.links ? `\n\nПосилання: ${v.links}` : '';
    return `Доброго дня,

Мене зацікавила ваша вакансія ${v.vacancy.title}${co}.

Маю ${v.exp}+ ${plural(v.exp, 'рік','роки','років')} досвіду роботи DevOps-інженером. У своїй практиці активно використовую ${tags}. Маю досвід побудови CI/CD пайплайнів, налаштування моніторингу та автоматизації інфраструктури в production середовищах.${v.vacancy.level ? `\n\nПозиція ${v.vacancy.level} відповідає моєму поточному рівню — готовий взяти на себе відповідальність за весь lifecycle інфраструктури.` : ''}

Уважно ознайомився з описом вакансії. Впевнений, що мій технічний бекграунд дозволить швидко влитись у команду та принести реальну цінність.${links}

Буду радий поспілкуватись та пройти технічне інтерв'ю у зручний для вас час.

З повагою,
${v.name}`;
  },

  motivational(v) {
    const co    = v.vacancy.company || 'вашої компанії';
    const tags  = v.vacancy.tags.slice(0, 4);
    const stack = tags.length > 0
      ? `Стек ${tags.join(' + ')} — саме те, з чим я працюю щодня`
      : 'Ваш технічний стек мені добре знайомий';
    const links = v.links ? `\n\n${v.links}` : '';
    return `Привіт команді ${co},

Побачив вашу вакансію ${v.vacancy.title} — і вирішив написати одразу.

${stack}. За останні ${v.exp} ${plural(v.exp,'рік','роки','років')} я будував інфраструктуру, яка тримає навантаження в production, автоматизував рутину через IaC та CI/CD, і знаю ціну стабільного деплою о 23:00 у п'ятницю.

Мені подобається, коли є реальні технічні виклики, а не просто "підтримка легасі". Якщо у вашій команді саме такий підхід — хочу бути частиною цього.${links}

Напишіть, якщо готові поспілкуватись. Дзвінок на 30 хвилин — і ми зрозуміємо, чи є match.

${v.name}`;
  },

  technical(v) {
    const co    = v.vacancy.company ? ` — ${v.vacancy.company}` : '';
    const tags  = v.vacancy.tags;
    const lines = tags.length > 0
      ? tags.slice(0, 8).map(t => `✓ ${t}`).join('\n')
      : '✓ Docker / Kubernetes\n✓ CI/CD (GitHub Actions / GitLab CI)\n✓ Terraform / Ansible\n✓ Prometheus / Grafana\n✓ Linux, Bash, Python';
    const links = v.links
      ? `\nПосилання: ${v.links}`
      : '';
    return `Доброго дня,

Відгукуюсь на позицію ${v.vacancy.title}${co}.

Досвід роботи: ${v.exp}+ ${plural(v.exp,'рік','роки','років')}

Технології з вакансії, з якими маю hands-on досвід:
${lines}

Коротко про підхід:
• Інфраструктура як код — Terraform + Ansible, все в git
• CI/CD з нуля: від Dockerfile до production-деплою з rollback
• Моніторинг: Prometheus + Grafana + алертинг на всіх рівнях
• Безпека: RBAC, Vault для секретів, Trivy у пайплайні${links}

Готовий до технічного інтерв'ю в будь-який зручний день.

${v.name}`;
  },
};

function plural(n, one, few, many) {
  const num = parseInt(n) || 0;
  if (num % 10 === 1 && num % 100 !== 11) return one;
  if ([2,3,4].includes(num % 10) && ![12,13,14].includes(num % 100)) return few;
  return many;
}

function regenerate() {
  const v   = getCoverVars();
  const fn  = TEMPLATES[currentTpl];
  if (!fn) return;
  const out = document.getElementById('cover-output');
  if (out) out.value = fn(v);
}

function copyCover() {
  const out    = document.getElementById('cover-output');
  const status = document.getElementById('cover-status');
  if (!out?.value.trim()) return;
  navigator.clipboard.writeText(out.value).then(() => {
    status.textContent = 'Скопійовано!';
    setTimeout(() => { status.textContent = ''; }, 2000);
  });
}

// ─── Dark mode ────────────────────────────────────────────────────
function toggleDark() {
  const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  const next = isDark ? 'light' : 'dark';
  document.documentElement.setAttribute('data-theme', next);
  localStorage.setItem('theme', next);
  document.getElementById('btn-dark').textContent = next === 'dark' ? '☀' : '🌙';
}
(function initTheme() {
  const saved = localStorage.getItem('theme') || 'light';
  if (saved === 'dark') {
    document.documentElement.setAttribute('data-theme', 'dark');
    const btn = document.getElementById('btn-dark');
    if (btn) btn.textContent = '☀';
  }
})();
</script>

