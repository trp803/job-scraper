    },

    // ── ПОРАДИ (best practices для вищого score) ─────────────────
    {
      severity: 'info', label: 'Ім\'я виділено великим шрифтом',
      ok: /\\(?:Huge|LARGE|Large)\s*(?:\\scshape\s*)?[A-ZА-ЯІЇЄ]/.test(latex),
      fix: 'Ім\'я має бути найбільшим елементом — ATS визначає його як ідентифікатор кандидата.',
      template: '\\textbf{\\Huge \\scshape Ім\'я Прізвище}',
    },
    {
      severity: 'info', label: 'Вказано місто або Remote',
      ok: /Київ|Kyiv|Lviv|Львів|Харків|Kharkiv|Ukraine|Україна|Remote|remote|Дніпро|Одеса|Запоріж/i.test(latex),
      fix: 'Вкажи місто або "Remote" — частина ATS систем фільтрує кандидатів за локацією.',
      template: 'Kyiv, Ukraine $|$ Remote',
    },
    {
      severity: 'info', label: 'Секція Certifications',
      ok: /\\section\s*\{[^}]*(Certif|Сертиф)/i.test(latex),
      fix: 'CKA, AWS SAA, CKAD — вагомий сигнал для ATS у DevOps вакансіях. Окрема секція підвищує keyword score.',
      template: '\\section{Certifications}\n\\resumeSubHeadingListStart\n  \\resumeProjectHeading{\\textbf{AWS Certified Solutions Architect} -- Associate}{2024}\n  \\resumeProjectHeading{\\textbf{Certified Kubernetes Administrator (CKA)}}{2023}\n\\resumeSubHeadingListEnd',
    },
    {
      severity: 'info', label: 'Секція Projects',
      ok: /\\section\s*\{[^}]*(Project|Проєкт|Проект)/i.test(latex),
      fix: 'Open-source або pet проєкти показують практичний досвід. ATS враховує їх при keyword matching.',
      template: '\\section{Projects}\n\\resumeSubHeadingListStart\n  \\resumeProjectHeading{\\textbf{Назва проєкту} $|$ \\emph{Kubernetes, Terraform, ArgoCD}}{2024}\n    \\resumeItemListStart\n      \\resumeItem{Опис що зробив та результат}\n    \\resumeItemListEnd\n\\resumeSubHeadingListEnd',
    },
    {
      severity: 'info', label: 'Навички списком (не суцільним текстом)',
      ok: /\\textbf\{[^}]+\}\{:/.test(latex) || /\\textbf\{[^}]+\}:/.test(latex),
      fix: 'У секції Skills використовуй "\\textbf{Cloud}{: AWS, GCP}" замість суцільного абзацу — ATS краще парсить структуровані категорії.',
    },
    {
      severity: 'info', label: 'Обсяг: 5–40 bullet points (~1–2 сторінки)',
      ok: (() => {
        const n = (latex.match(/\\resumeItem|\\item\s+\S/g) || []).length;
        return n >= 5 && n <= 45;
      })(),
      fix: 'Менше 5 пунктів — резюме виглядає порожнім. Більше 45 — швидше за все більше 2 сторінок. ATS знижує score за нестандартний обсяг.',
    },
  ];

  // ── Score (вага: critical=3, warning=2, info=1) ───────────────
  const weights    = { critical: 3, warning: 2, info: 1 };
  const maxScore   = checks.reduce((s, c) => s + weights[c.severity], 0);
  const gotScore   = checks.filter(c => c.ok).reduce((s, c) => s + weights[c.severity], 0);
  const pct        = Math.round(gotScore / maxScore * 100);
  const color      = pct >= 80 ? '#16a34a' : pct >= 55 ? '#d97706' : '#dc2626';
  const passed     = checks.filter(c => c.ok).length;

  // ── Render helpers ────────────────────────────────────────────
  const esc = s => s.replace(/</g,'&lt;').replace(/>/g,'&gt;');

  const renderGroup = (title, sev, icon) => {
    const items  = checks.filter(c => c.severity === sev);
    const failed = items.filter(c => !c.ok);
    const ok     = items.filter(c => c.ok);
    if (items.length === 0) return '';
    let h = `<div class="ats-group">
      <div class="ats-group-title ats-${sev}">
        ${icon} ${title}
        <span class="ats-group-count">${ok.length}/${items.length}</span>
      </div>`;
    for (const c of [...failed, ...ok]) {
      const tplJson = c.template ? JSON.stringify(c.template) : null;
      h += `<div class="ats-item${c.ok ? ' ats-item-ok' : ''}">
        <span class="ats-icon">${c.ok ? '✅' : (sev === 'critical' ? '🔴' : sev === 'warning' ? '🟡' : '💡')}</span>
        <div class="ats-item-body">
          <div class="ats-label">${c.label}</div>
          ${!c.ok ? `<div class="ats-hint">${c.fix}</div>` : ''}
          ${!c.ok && tplJson ? `
            <div class="ats-template"><code>${esc(c.template).replace(/\n/g, ' ↵ ')}</code></div>
            <button class="ats-insert-btn" onclick="insertAtsTemplate(${esc(tplJson)})">↳ Вставити в редактор</button>
          ` : ''}
        </div>
      </div>`;
    }
    return h + '</div>';
  };

  results.innerHTML = `
    <div class="ats-score-bar"><div class="ats-score-fill" style="width:${pct}%;background:${color}"></div></div>
    <div class="ats-score-text">
      ATS Score: <b style="color:${color}">${pct}%</b>
      <span style="color:var(--text-muted)">&nbsp;(${passed}/${checks.length} пройдено)</span>
    </div>
    ${renderGroup('Критичні — ATS може відхилити', 'critical', '🔴')}
    ${renderGroup('Попередження — знижують score', 'warning',  '🟡')}
    ${renderGroup('Поради — best practices',        'info',     '💡')}
    <button class="kw-copy-missing" style="margin-top:.6rem" onclick="copyAtsReport()">
      Скопіювати звіт
    </button>`;

  // Зберігаємо checks для звіту
  window._lastAtsChecks = checks;
}

function insertAtsTemplate(code) {
  editor.focus();
  editor.replaceSelection(code);
}

function copyAtsReport() {
  const checks = window._lastAtsChecks || [];
  const lines  = checks.filter(c => !c.ok).map(c => `❌ [${c.severity.toUpperCase()}] ${c.label}\n   → ${c.fix}`);
  const text   = `ATS Звіт резюме\n${'─'.repeat(40)}\nПроблеми (${lines.length}):\n\n${lines.join('\n\n')}`;
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.querySelector('[onclick="copyAtsReport()"]');
    if (btn) { btn.textContent = 'Скопійовано!'; setTimeout(() => { btn.textContent = 'Скопіювати звіт'; }, 2000); }
  });
}

// ─── Cover letter generation ──────────────────────────────────────
async function generateCoverLetter() {
  const vacText  = getVacancyText();
  const latex    = editor.getValue();
  const btn      = document.getElementById('btn-generate-cl');
  const content  = document.getElementById('cl-content');

  if (!vacText.trim()) {
    switchTab('vacancy');
    const ta = document.getElementById('vacancy-paste');
    if (ta) ta.focus();
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Генерую...';
  content.innerHTML = '<p class="cl-hint">Claude AI думає... зазвичай 10–20 секунд.</p>';

  try {
    const resp = await fetch('/cover-letter/generate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ vacancy_text: vacText, resume_latex: latex }),
    });
    const data = await resp.json();

    if (!data.ok) {
      content.innerHTML = `<div class="cl-error">${data.error}</div>`;
      return;
    }

    content.innerHTML = `
      <textarea class="cl-textarea" id="cl-textarea" spellcheck="true">${data.text.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</textarea>
      <div class="cl-actions">
        <button class="cl-copy-btn" onclick="copyCoverLetter()">Копіювати</button>
        <button class="cl-generate-btn" style="width:auto;padding:.4rem 1rem;margin:0" onclick="generateCoverLetter()">Перегенерувати</button>
      </div>`;
  } catch (e) {
    content.innerHTML = `<div class="cl-error">Помилка з'єднання: ${e.message}</div>`;
  } finally {
    btn.disabled = false;
    btn.textContent = 'Згенерувати супровідний лист';
  }
}

function copyCoverLetter() {
  const ta = document.getElementById('cl-textarea');
  if (!ta) return;
  navigator.clipboard.writeText(ta.value).then(() => {
    const btn = document.querySelector('.cl-copy-btn');
    if (btn) { btn.textContent = 'Скопійовано!'; setTimeout(() => { btn.textContent = 'Копіювати'; }, 2000); }
  });
}

// ─── Vacancy text helpers ─────────────────────────────────────────
function getVacancyText() {
  // Спочатку — серверний опис вакансії
  const desc = document.querySelector('.vacancy-info-desc');
  if (desc && desc.textContent.trim()) return desc.textContent;
  // Потім — textarea (ручна вставка)
  const ta = document.getElementById('vacancy-paste');
  if (ta && ta.value.trim()) return ta.value;
  return '';
}

