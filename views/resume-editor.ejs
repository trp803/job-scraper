// ─── Keyword analysis logic ───────────────────────────────────────
function escapeRx(s) {
  return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

function analyzeVacancy() {
  const vacText  = getVacancyText();
  const latex    = editor.getValue();
  const btn      = document.getElementById('btn-analyze');
  const resultsEl = document.getElementById('kw-results');

  if (!vacText.trim()) {
    // Якщо тексту немає — перемкнути на вкладку вакансії
    switchTab('vacancy');
    const ta = document.getElementById('vacancy-paste');
    if (ta) ta.focus();
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Аналіз...';

  // Невеликий тайм-аут щоб UI оновився до важкого обчислення
  setTimeout(() => {
    const found    = {};   // category → [{kw, inResume}]
    let totalFound = 0;
    let totalMiss  = 0;

    for (const [cat, keywords] of Object.entries(KW_DB)) {
      const hits = [];
      for (const kw of keywords) {
        const rx = new RegExp('(?<![\\w-])' + escapeRx(kw) + '(?![\\w-])', 'i');
        if (rx.test(vacText)) {
          const inResume = new RegExp('(?<![\\w-])' + escapeRx(kw) + '(?![\\w-])', 'i').test(latex);
          hits.push({ kw, inResume });
          totalFound++;
          if (!inResume) totalMiss++;
        }
      }
      if (hits.length) found[cat] = hits;
    }

    btn.disabled = false;
    btn.textContent = 'Оновити аналіз';

    // Бейдж на вкладці
    const badge = document.getElementById('kw-badge');
    if (totalMiss > 0) {
      badge.textContent = totalMiss;
      badge.style.display = '';
    } else {
      badge.style.display = 'none';
    }

    if (totalFound === 0) {
      resultsEl.innerHTML = '<div class="kw-empty">Ключових слів DevOps/Cloud не знайдено у вакансії. Спробуй вставити більше тексту з описом позиції.</div>';
      return;
    }

    // Рендер
    let html = `
      <div class="kw-stats">
        Знайдено в вакансії: <b>${totalFound}</b> &nbsp;·&nbsp;
        Вже в резюме: <b style="color:#166534">${totalFound - totalMiss}</b> &nbsp;·&nbsp;
        Потрібно додати: <b style="color:#92400e">${totalMiss}</b>
      </div>
      <div class="kw-legend">
        <span><span class="kw-legend-dot" style="background:#86efac"></span>Вже в резюме</span>
        <span><span class="kw-legend-dot" style="background:#fde68a"></span>Відсутні — клік → вставить</span>
      </div>
    `;

    for (const [cat, hits] of Object.entries(found)) {
      html += `<div class="kw-section"><div class="kw-section-title">${cat}</div><div class="kw-chips">`;
      for (const { kw, inResume } of hits) {
        if (inResume) {
          html += `<span class="kw-chip found" title="Вже є в резюме">${kw}</span>`;
        } else {
          // data-kw через escaping
          const safe = kw.replace(/"/g, '&quot;');
          html += `<span class="kw-chip missing" data-kw="${safe}" onclick="insertKw(this)" title="Клік → вставити в редактор">${kw}</span>`;
        }
      }
      html += `</div></div>`;
    }

    // Кнопка "скопіювати всі відсутні"
    if (totalMiss > 0) {
      html += `<button class="kw-copy-missing" onclick="copyAllMissing()">Скопіювати всі відсутні ключові слова</button>`;
    }

    resultsEl.innerHTML = html;
  }, 30);
}

// ─── Insert keyword at cursor ────────────────────────────────────
function insertKw(chipEl) {
  const kw = chipEl.dataset.kw;
  if (!kw) return;
  editor.focus();
  editor.replaceSelection(kw);

  // Позначити чип як доданий
  chipEl.classList.remove('missing');
  chipEl.classList.add('found');
  chipEl.onclick = null;
  chipEl.title = 'Вже є в резюме';

  // Оновити лічильник у бейджі
  const badge = document.getElementById('kw-badge');
  const cur   = parseInt(badge.textContent) || 0;
  if (cur <= 1) { badge.style.display = 'none'; }
  else { badge.textContent = cur - 1; }
}

// ─── Copy all missing keywords ────────────────────────────────────
function copyAllMissing() {
  const chips = document.querySelectorAll('.kw-chip.missing');
  const text  = Array.from(chips).map(c => c.dataset.kw).join(', ');
  if (!text) return;
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.querySelector('.kw-copy-missing');
    if (btn) { btn.textContent = 'Скопійовано!'; setTimeout(() => { btn.textContent = 'Скопіювати всі відсутні ключові слова'; }, 2000); }
  });
}

// ─── Темна тема ───────────────────────────────────────────────────
function toggleDark() {
  const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  const next   = isDark ? 'light' : 'dark';
  document.documentElement.setAttribute('data-theme', next);
  localStorage.setItem('theme', next);
  document.getElementById('btn-dark').textContent = next === 'dark' ? '☀' : '🌙';
  editor.setOption('theme', next === 'dark' ? 'dracula' : 'default');
}
(function() {
  const saved = localStorage.getItem('theme') || 'light';
  if (saved === 'dark') {
    document.documentElement.setAttribute('data-theme', 'dark');
    const btn = document.getElementById('btn-dark');
    if (btn) btn.textContent = '☀';
  }
})();
</script>

